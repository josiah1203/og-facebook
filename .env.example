# Database (MySQL connection string)
DATABASE_URL=mysql://user:password@localhost:3306/ogfacebook

# OAuth platform (Kimi Open)
APP_ID=your-kimi-app-id
APP_SECRET=your-kimi-app-secret
KIMI_AUTH_URL=https://auth.kimi.ai
KIMI_OPEN_URL=https://api.kimi.ai

# Optional: set this to the unionId of the account that should receive the admin role on first sign-in
OWNER_UNION_ID=

# Server
NODE_ENV=development
PORT=3000
