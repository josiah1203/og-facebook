# Database (SQLite for local development)
DATABASE_URL=file:./og.db

# OAuth platform (Kimi Open) - can be empty for local testing
APP_ID=
APP_SECRET=test-secret-key
KIMI_AUTH_URL=https://auth.kimi.ai
KIMI_OPEN_URL=https://api.kimi.ai

# Optional: set this to the unionId of the account that should receive the admin role on first sign-in
OWNER_UNION_ID=

# Server
NODE_ENV=development
PORT=3000


